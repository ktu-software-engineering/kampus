# Bu dosyayı kopyalayıp .env.local olarak kaydet
# Gerçek değerleri Supabase dashboard'undan al
# .env.local dosyasını ASLA Git'e ekleme — .gitignore'da zaten var

# Supabase — Public (istemci tarafında kullanılabilir)
NEXT_PUBLIC_SUPABASE_URL=https://PROJE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — Gizli (sadece sunucu tarafında, asla istemciye gönderilmez)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — E-posta gönderimi (Supabase custom SMTP)
RESEND_API_KEY=re_...
